      "id": "73abc2f2-7fbc-48ec-9772-dc3674cdf9f2",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst KPIs = items.map((item) => {\n  let revenue = item.json.Revenue;\n  let growth =\n    ((revenue - item.json.Previous_Week_Revenue) /\n      item.json.Previous_Week_Revenue) *\n    100;\n  let targetAchievement = (revenue / item.json.Weekly_Target) * 100;\n  return { ...item.json, revenue, growth, targetAchievement };\n});\n\nconst topPerformer = KPIs.reduce((prev, current) =>\n  prev.revenue > current.revenue ? prev : current,\n);\n\nKPIs.forEach((item) => {\n  if (item.Rep_Name === topPerformer.Rep_Name) {\n    item.topPerformer = true;\n  }\n});\n\nreturn KPIs.map((item) => ({ json: item }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        0
      ],
      "id": "ea4998f2-aa67-4ffd-ad37-892ebc438647",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const reps = $input.all().map((item) => item.json);\n\nconst flaggedReps = reps.map((rep) => {\n  const dropPercentage =\n    (rep.Previous_Week_Revenue - rep.Revenue) / rep.Previous_Week_Revenue;\n  rep.flagged = dropPercentage > 0.2;\n  return rep;\n});\n\nreturn flaggedReps;\n"
      },
