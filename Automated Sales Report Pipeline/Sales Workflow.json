      "parameters": {
        "jsCode": "const data = $input.all().map((item) => item.json);\n\nconst htmlReport = data\n  .map((item) => {\n    let html = `<div><h1>${item[\"Total Revenue\"]}</h1><ul>`;\n    html += `<li>Total Units Sold: ${item[\"Total__Units_Sold\"]}</li>`;\n    html += `<li>Previous Week Revenue: ${item[\"Previous_Week_Revenue\"]}</li>`;\n    html += \"</ul></div>\";\n    return html;\n  })\n  .join(\"\");\n\nreturn [{ json: { htmlReport }, pairedItem: data.map((_, index) => index) }];\n"
      },
